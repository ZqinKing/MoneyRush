# MoneyRush 环境变量示例
# 使用方式：复制为仓库根目录下的 .env 后按需修改。
# 本文件只保留普通部署/开发常用配置；采集频率、重试、缓存 key 等内部参数使用项目默认值。
# 请不要在示例文件中提交真实密钥。

# =============================================================================
# 1. 基础运行环境
# =============================================================================

# 应用运行环境标识；本地开发保持 development 即可。
APP_ENV=development

# 宿主机访问前端的端口；默认访问 http://localhost:5173。
FRONTEND_PORT=5173


# =============================================================================
# 2. PostgreSQL / TimescaleDB 数据库
# =============================================================================

# Compose 会用以下三项初始化数据库，并为后端/采集器拼接连接串。
POSTGRES_DB=moneyrush
POSTGRES_USER=moneyrush

# 仅适合本地开发的默认密码；生产或公网环境请务必替换。
POSTGRES_PASSWORD=moneyrush


# =============================================================================
# 3. 功能模块开关
# =============================================================================

# 个股研报、公告、新闻等内容采集。
CONTENT_COLLECTOR_ENABLED=true

# 大盘概览采集。
MARKET_OVERVIEW_COLLECTOR_ENABLED=true

# 黄金看板采集。
GOLD_DASHBOARD_COLLECTOR_ENABLED=true

# 全球股市看板采集。
GLOBAL_MARKETS_COLLECTOR_ENABLED=true

# 龙虎榜采集。
DRAGON_TIGER_COLLECTOR_ENABLED=true

# 个股资金流采集。
CAPITAL_FLOW_COLLECTOR_ENABLED=true

# 基金持仓与关联股票采集。
FUND_COLLECTOR_ENABLED=true

# 宏观监控展示与宏观数据采集。
MACRO_MONITOR_ENABLED=true
MACRO_COLLECTOR_ENABLED=true


# =============================================================================
# 4. 全球股市看板配置
# =============================================================================

# 全球股市采集刷新间隔、请求超时与数据过期提示阈值；均为非密钥运行参数。
GLOBAL_MARKETS_REFRESH_SECONDS=30
GLOBAL_MARKETS_REQUEST_TIMEOUT_SECONDS=10
GLOBAL_MARKETS_STALE_AFTER_MINUTES=30

# 后端与采集器共享的 Redis 缓存 key；如需修改必须两端保持一致。
GLOBAL_MARKETS_CACHE_KEY=moneyrush:global_markets:latest


# =============================================================================
# 5. 外部凭据与 AI 配置
# =============================================================================

# FRED API Key；留空时使用公开访问能力，受限时再填写自己的 key。
FRED_API_KEY=

# OpenAI 兼容接口地址、密钥和模型名；留空时跳过依赖 AI 的增强分析。
AI_BASE_URL=
AI_API_KEY=
AI_MODEL=

# 主模型不可用时使用的后备模型；留空则不启用后备。
AI_FALLBACK_MODEL=


# =============================================================================
# 6. 前端访问覆盖项
# =============================================================================

# 默认留空：前端使用同源 /api 和 /ws，并由 Vite/Compose 代理到后端。
# 只有在前端需要直连外部 API 或 WebSocket 地址时才填写。
VITE_API_BASE_URL=
VITE_WS_BASE_URL=
